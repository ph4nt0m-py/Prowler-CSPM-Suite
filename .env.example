# Database
DATABASE_URL=postgresql+psycopg2://prowler:prowler@postgres:5432/cloudaudit

# Redis (Celery broker + pub/sub for scan progress)
REDIS_URL=redis://redis:6379/0

# API
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENCRYPTION_KEY=
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Prowler execution (worker)
PROWLER_IMAGE=prowlercloud/prowler:stable
# Worker: periodic docker pull for PROWLER_IMAGE (same schedule offset as beat; requires DOCKER_AVAILABLE)
PROWLER_AUTO_PULL=false
SCAN_OUTPUT_DIR=/data/scans
# Set true when worker container has Docker socket mounted (local dev)
DOCKER_AVAILABLE=true

# Optional: higher GitHub API rate limit for version checks
GITHUB_TOKEN=

# CORS (comma-separated origins for SPA)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend (Vite) - API base URL as seen from browser
VITE_API_URL=http://localhost:8000

# Docker Compose: host ports (if 8000 is busy: API_PORT=8001 docker compose up --build)
# API_PORT=8000
# WEB_PORT=5173
